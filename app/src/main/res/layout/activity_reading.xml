<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootReading"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/read_bg_default">

    <!-- 常驻顶部：左文件名 · 右当前章节（各最多 50% 宽，超出省略） -->
    <LinearLayout
        android:id="@+id/readTitleBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvBookName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical|start"
            android:maxLines="1"
            android:paddingEnd="6dp"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvChapterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical|end"
            android:maxLines="1"
            android:paddingStart="6dp"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 兼容旧引用：隐藏，避免部分代码崩溃（逐步清理） -->
    <TextView
        android:id="@+id/tvReadTitle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 点击中心弹出的工具栏（盖在标题之上） -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="#F8F8F8"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back" />

        <!-- 中间占位：不再显示文件名 -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnBookmark"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/bookmark"
            android:src="@drawable/ic_bookmark_border" />

        <TextView
            android:id="@+id/btnEncoding"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="@string/encoding_btn"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/search"
            android:src="@drawable/ic_search" />
    </LinearLayout>

    <!-- 底栏叠加，正文区始终到底，避免展开菜单时高度变化误关菜单 -->
    <com.whj.reader.ui.VirtualReaderView
        android:id="@+id/readerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/readTitleBar" />

    <!-- 常驻底部：电量 · 时间 · 进度（叠在正文上，需有底色） -->
    <LinearLayout
        android:id="@+id/readStatusBar"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:background="@color/read_bg_default"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomChrome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:text="--%"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="--:--"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="0.00%"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 底部区域：菜单 / TTS（叠加在正文上） -->
    <LinearLayout
        android:id="@+id/bottomChrome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:id="@+id/readMenuHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/ttsExportHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ttsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tts_bar"
            android:elevation="6dp"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTtsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:text="@string/tts_idle"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnTtsPrev"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_prev"
                    android:src="@drawable/ic_prev" />

                <ImageButton
                    android:id="@+id/btnTtsPlayPause"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_play"
                    android:src="@drawable/ic_play" />

                <ImageButton
                    android:id="@+id/btnTtsNext"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_next"
                    android:src="@drawable/ic_next" />

                <ImageButton
                    android:id="@+id/btnTtsStop"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_stop"
                    android:src="@drawable/ic_stop" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTtsRate"
                    style="@style/Widget.WhjReader.TtsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="1.0×"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTtsSleep"
                    style="@style/Widget.WhjReader.TtsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/tts_sleep"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTtsSleepCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingHorizontal="8dp"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnVoice"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_voice"
                    android:src="@drawable/ic_voice" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTtsRetry"
                    style="@style/Widget.WhjReader.TtsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tts_retry" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/settingsPanelContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/settingsScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <include
            android:id="@+id/settingsPanel"
            layout="@layout/panel_read_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />
    </FrameLayout>

    <!-- 打开书籍加载遮罩（EPUB 等大书） -->
    <LinearLayout
        android:id="@+id/loadOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E6FFFFFF"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:id="@+id/progressLoad"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:max="100" />

        <TextView
            android:id="@+id/tvLoadMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/loading_book"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvLoadDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
