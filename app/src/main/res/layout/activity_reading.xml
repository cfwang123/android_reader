<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootReading"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/read_bg_default">

    <!-- 常驻顶部：书名 -->
    <TextView
        android:id="@+id/tvReadTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center_vertical|start"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 点击中心弹出的工具栏（盖在标题之上） -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="#F8F8F8"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.whj.reader.ui.VirtualReaderView
        android:id="@+id/readerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/readStatusBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvReadTitle" />

    <!-- 常驻底部：电量 · 时间 · 进度 -->
    <LinearLayout
        android:id="@+id/readStatusBar"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomChrome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:text="--%"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="--:--"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="0.00%"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 底部区域：菜单 / TTS -->
    <LinearLayout
        android:id="@+id/bottomChrome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include
            android:id="@+id/readMenu"
            layout="@layout/panel_read_menu"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ttsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tts_bar"
            android:elevation="6dp"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTtsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:text="@string/tts_idle"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnTtsPrev"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_prev"
                    android:src="@drawable/ic_prev" />

                <ImageButton
                    android:id="@+id/btnTtsPlayPause"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_play"
                    android:src="@drawable/ic_play" />

                <ImageButton
                    android:id="@+id/btnTtsNext"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_next"
                    android:src="@drawable/ic_next" />

                <ImageButton
                    android:id="@+id/btnTtsStop"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_stop"
                    android:src="@drawable/ic_stop" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- 语速 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTtsRateDown"
                    style="@style/Widget.WhjReader.TtsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="36dp"
                    android:text="−"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvTtsRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="40dp"
                    android:gravity="center"
                    android:text="1.0×"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTtsRateUp"
                    style="@style/Widget.WhjReader.TtsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="36dp"
                    android:text="+"
                    android:textSize="16sp" />

                <ImageButton
                    android:id="@+id/btnVoice"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/tts_voice"
                    android:src="@drawable/ic_voice" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTtsRetry"
                    style="@style/Widget.WhjReader.TtsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tts_retry" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/settingsPanelContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/settingsScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <include
            android:id="@+id/settingsPanel"
            layout="@layout/panel_read_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
