<?xml version="1.0" encoding="utf-8"?>
<!-- CX 风格文件行：无卡片边框、紧凑间距、右侧多选框 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_list_item"
    android:foreground="?attr/selectableItemBackground"
    android:minHeight="56dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/ivFileType"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_file_txt" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivDragHandle"
            android:layout_width="28dp"
            android:layout_height="36dp"
            android:contentDescription="@string/drag_to_reorder"
            android:padding="2dp"
            android:src="@drawable/ic_drag_handle"
            android:visibility="gone" />

        <!-- 右侧多选框（对齐 CX 文件管理器） -->
        <ImageView
            android:id="@+id/ivCheck"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:contentDescription="@string/selection_mode"
            android:padding="2dp"
            android:src="@drawable/ic_check_box_outline"
            android:visibility="gone" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressRead"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="bottom"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/shelf_progress_bar"
        android:visibility="invisible" />
</FrameLayout>
