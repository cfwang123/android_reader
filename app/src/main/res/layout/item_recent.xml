<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_round_card"
    android:foreground="?attr/selectableItemBackground"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/ivCheck"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/selection_mode"
            android:src="@drawable/ic_check_box_outline"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivFileType"
            android:layout_width="40dp"
            android:layout_height="52dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_file_txt" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 第 1 行：完整文件名（含扩展名） -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- 保留 id 兼容绑定；默认隐藏（不再显示路径第 2 行） -->
            <TextView
                android:id="@+id/tvPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivDragHandle"
            android:layout_width="32dp"
            android:layout_height="40dp"
            android:contentDescription="@string/drag_to_reorder"
            android:padding="4dp"
            android:src="@drawable/ic_drag_handle"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 底部绿色阅读进度条 -->
    <ProgressBar
        android:id="@+id/progressRead"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="bottom"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/shelf_progress_bar" />
</FrameLayout>
